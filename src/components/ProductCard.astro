---
import { Image } from "astro:assets";
interface Props {
    product: {
        title: string;
        category: string;
        categoryColor: string;
        price: string;
        image: string;
        url: string;
        badge: string | null;
        imageBg?: string;
    };
}

const { product } = Astro.props;
const imageBg = product.imageBg || "bg-white";
---

<div
    class="bg-card-light dark:bg-card-dark rounded-2xl overflow-hidden shadow-lg border border-gray-100 dark:border-gray-700 hover:-translate-y-2 hover:shadow-2xl transition-all duration-500 flex flex-col group relative"
>
    {
        product.badge && (
            <div class="absolute top-3 right-3 bg-secondary/90 text-gold text-[10px] font-bold uppercase px-2 py-1 rounded z-10 backdrop-blur-sm">
                {product.badge}
            </div>
        )
    }
    <div class={`relative overflow-hidden ${imageBg}`}>
        <Image
            alt={product.title}
            src={product.image}
            width={500}
            height={500}
            class="w-full h-full aspect-square object-cover rounded-xl transition-transform duration-500 group-hover:scale-110"
        />
    </div>
    <div class="p-6 flex flex-col flex-grow">
        <p
            class={`text-[10px] font-bold ${product.categoryColor} tracking-widest uppercase mb-1`}
        >
            {product.category}
        </p>
        <h3
            class="font-display text-lg font-bold text-secondary dark:text-white mb-2 line-clamp-2 tracking-tighter"
        >
            {product.title}
        </h3>
        <!-- Star Rating -->
        <div class="flex items-center gap-0.5 mb-4 text-gold">
            <span class="material-symbols-outlined text-[14px]">star</span>
            <span class="material-symbols-outlined text-[14px]">star</span>
            <span class="material-symbols-outlined text-[14px]">star</span>
            <span class="material-symbols-outlined text-[14px]">star</span>
            <span class="material-symbols-outlined text-[14px]">star</span>
            <span class="text-[10px] text-gray-500 dark:text-gray-400 ml-1"
                >(5.0)</span
            >
        </div>
        <div class="mt-auto">
            <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                <span
                    class="font-mono text-[1.1rem] font-bold text-gray-900 dark:text-white tracking-tighter"
                >
                    {product.price}
                </span>
                <div class="flex items-center gap-2">
                    <a
                        href={product.url}
                        class="font-mono border-2 border-secondary text-secondary dark:border-gold dark:text-gold hover:bg-secondary hover:text-white dark:hover:bg-gold dark:hover:text-secondary p-2 rounded-lg font-bold transition-all flex items-center justify-center"
                        aria-label="Ver detalles"
                    >
                        <span class="material-symbols-outlined text-[16px]"
                            >visibility</span
                        >
                    </a>
                    <button
                        class="flex-1 xl:flex-none product-card-add-btn font-mono bg-[#A03D45] text-white hover:bg-red-800 px-5 py-2 rounded-lg font-bold transition-all text-xs uppercase tracking-widest flex items-center justify-center gap-2 w-full"
                        data-product={JSON.stringify(product)}
                    >
                        <span class="material-symbols-outlined text-[14px]"
                            >shopping_cart</span
                        >
                        Añadir
                    </button>
                </div>
            </div>
            <!-- Trust Icons -->
            <div
                class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 pt-4 border-t border-gray-100 dark:border-gray-800 opacity-70 group-hover:opacity-100 transition-opacity"
            >
                <div class="flex items-center gap-1" title="Envío 24h">
                    <span class="material-symbols-outlined text-[13px]"
                        >local_shipping</span
                    >
                    <span
                        class="text-[8.5px] font-bold uppercase tracking-widest"
                        >Envío 24h</span
                    >
                </div>
                <div class="flex items-center gap-1" title="Paquete Discreto">
                    <span class="material-symbols-outlined text-[13px]"
                        >visibility_off</span
                    >
                    <span
                        class="text-[8.5px] font-bold uppercase tracking-widest"
                        >Discreto</span
                    >
                </div>
                <div class="flex items-center gap-1" title="Pago Seguro">
                    <span class="material-symbols-outlined text-[13px]"
                        >lock</span
                    >
                    <span
                        class="text-[8.5px] font-bold uppercase tracking-widest"
                        >Pr. Seguro</span
                    >
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const addBtns = document.querySelectorAll(".product-card-add-btn");
        addBtns.forEach((btn) => {
            // Ensure we handle clicks properly
            btn.addEventListener("click", (e) => {
                const button = e.currentTarget as HTMLElement;
                const productData = JSON.parse(button.dataset.product || "{}");
                if ((window as any).addToCartGlobal) {
                    const id =
                        productData.id ||
                        productData.url?.split("/").pop() ||
                        productData.title.replace(/\s+/g, "-").toLowerCase();
                    (window as any).addToCartGlobal({
                        ...productData,
                        id,
                        quantity: 1,
                    });
                }
            });
        });
    });
</script>
