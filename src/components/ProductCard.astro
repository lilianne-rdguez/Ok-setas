---
import { Image } from "astro:assets";
interface Props {
    product: {
        title: string;
        category: string;
        categoryColor: string;
        price: string;
        image: string;
        url: string;
        badge: string | null;
        imageBg?: string;
    };
}

const { product } = Astro.props;
const imageBg = product.imageBg || "bg-white";
---

<div
    class="bg-white/5 backdrop-blur-xl rounded-[2rem] border border-white/10 p-8 shadow-2xl flex flex-col group hover:-translate-y-2 hover:border-gold/30 transition-all duration-500 relative"
>
    {
        product.badge && (
            <div class="absolute top-4 left-4 bg-gold text-bg-dark text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest z-20 shadow-lg">
                {product.badge}
            </div>
        )
    }
    <div
        class="relative w-full aspect-square bg-white border border-white/10 rounded-2xl overflow-hidden p-6 flex items-center justify-center mb-8 shadow-inner"
    >
        <Image
            alt={product.title}
            src={product.image}
            width={500}
            height={500}
            class="w-full h-full object-contain transform group-hover:scale-110 group-hover:rotate-2 transition-transform duration-700 ease-out drop-shadow-xl"
        />
    </div>
    <div class="flex-1 flex flex-col w-full">
        <p
            class="text-gold uppercase tracking-widest text-[10px] font-bold mb-2 block"
        >
            {product.category}
        </p>
        <h3
            class="text-2xl font-bold text-white mb-4 tracking-tight leading-tight group-hover:text-gold transition-colors duration-300"
        >
            {product.title}
        </h3>

        <!-- Star Rating -->
        <div class="flex items-center gap-0.5 mb-6 text-gold/80">
            <span class="material-symbols-outlined text-[14px] fill-current"
                >star</span
            >
            <span class="material-symbols-outlined text-[14px] fill-current"
                >star</span
            >
            <span class="material-symbols-outlined text-[14px] fill-current"
                >star</span
            >
            <span class="material-symbols-outlined text-[14px] fill-current"
                >star</span
            >
            <span class="material-symbols-outlined text-[14px] fill-current"
                >star</span
            >
            <span class="text-[10px] text-gray-500 ml-2 font-mono">(5.0)</span>
        </div>

        <div class="mt-auto">
            <div class="mb-6 flex items-baseline gap-2">
                <span
                    class="text-3xl font-mono text-white font-bold tracking-tighter"
                >
                    {product.price}
                </span>
            </div>

            <div class="grid grid-cols-5 gap-2">
                <a
                    href={product.url}
                    class="col-span-1 border border-white/20 text-white hover:border-gold hover:text-gold p-3 rounded-xl transition-all flex items-center justify-center group/btn"
                    aria-label="Ver detalles"
                >
                    <span
                        class="material-symbols-outlined text-[20px] group-hover/btn:scale-110 transition-transform"
                        >visibility</span
                    >
                </a>
                <button
                    class="col-span-4 product-card-add-btn bg-gold text-bg-dark hover:bg-white px-4 py-3 rounded-xl font-bold transition-all text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 shadow-lg shadow-gold/10"
                    data-product={JSON.stringify(product)}
                >
                    <span class="material-symbols-outlined text-[18px]"
                        >shopping_cart</span
                    >
                    Añadir al carrito
                </button>
            </div>

            <!-- Trust Icons -->
            <div
                class="flex items-center justify-between mt-8 pt-6 border-t border-white/5 opacity-50 group-hover:opacity-100 transition-opacity duration-500"
            >
                <div class="flex flex-col items-center gap-1">
                    <span
                        class="material-symbols-outlined text-[16px] text-gold"
                        >local_shipping</span
                    >
                    <span
                        class="text-[7px] uppercase tracking-[0.2em] font-bold text-gray-400"
                        >Envío 24h</span
                    >
                </div>
                <div class="flex flex-col items-center gap-1">
                    <span
                        class="material-symbols-outlined text-[16px] text-gold"
                        >visibility_off</span
                    >
                    <span
                        class="text-[7px] uppercase tracking-[0.2em] font-bold text-gray-400"
                        >Discreto</span
                    >
                </div>
                <div class="flex flex-col items-center gap-1">
                    <span
                        class="material-symbols-outlined text-[16px] text-gold"
                        >lock</span
                    >
                    <span
                        class="text-[7px] uppercase tracking-[0.2em] font-bold text-gray-400"
                        >Seguro</span
                    >
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const addBtns = document.querySelectorAll(".product-card-add-btn");
        addBtns.forEach((btn) => {
            // Ensure we handle clicks properly
            btn.addEventListener("click", (e) => {
                const button = e.currentTarget as HTMLElement;
                const productData = JSON.parse(button.dataset.product || "{}");
                if ((window as any).addToCartGlobal) {
                    const id =
                        productData.id ||
                        productData.url?.split("/").pop() ||
                        productData.title?.replace(/\s+/g, "-").toLowerCase() ||
                        "product-" + Math.random().toString(36).substr(2, 9);
                    (window as any).addToCartGlobal({
                        ...productData,
                        id,
                        quantity: 1,
                    });
                } else {
                    console.error("CartDRAWER not ready");
                    if (typeof (window as any).openCart === "function")
                        (window as any).openCart();
                }
            });
        });
    });
</script>
