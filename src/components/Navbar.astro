---
---

<nav
    class="bg-secondary/80 backdrop-blur-md text-white w-full z-40 sticky top-0 border-b border-white/10"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-20 items-center">
            <a
                href="/"
                class="flex items-center gap-3 hover:opacity-80 transition-opacity"
            >
                <span class="material-symbols-outlined text-4xl"
                    >psychiatry</span
                >
                <span
                    class="font-sans font-bold text-2xl tracking-tight uppercase"
                    >GrowTrades</span
                >
            </a>
            <div
                class="hidden md:flex items-center space-x-6 lg:space-x-8 text-xs lg:text-sm tracking-wide font-medium text-gray-300"
            >
                <div class="relative group py-4">
                    <a
                        href="/productos"
                        class="flex items-center hover:text-gold transition-colors focus:outline-none uppercase"
                    >
                        PRODUCTOS
                        <span
                            class="material-symbols-outlined text-[1rem] ml-1 transition-transform group-hover:rotate-180"
                            >expand_more</span
                        >
                    </a>
                    <!-- Dropdown Content -->
                    <div
                        class="absolute left-0 top-full hidden group-hover:block w-56 bg-white dark:bg-card-dark rounded-xl shadow-2xl border border-gray-100 dark:border-gray-700 py-3 z-50 transform opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0"
                    >
                        <a
                            class="block px-5 py-2.5 text-gray-800 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gold dark:hover:text-gold transition-colors font-medium border-l-2 border-transparent hover:border-gold"
                            href="/microdosis">MICRODOSIS</a
                        >
                        <a
                            class="block px-5 py-2.5 text-gray-800 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gold dark:hover:text-gold transition-colors font-medium border-l-2 border-transparent hover:border-gold"
                            href="/trufas">TRUFAS MÁGICAS</a
                        >
                        <a
                            class="block px-5 py-2.5 text-gray-800 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800 hover:text-gold dark:hover:text-gold transition-colors font-medium border-l-2 border-transparent hover:border-gold"
                            href="/kits-de-cultivo">KITS DE CULTIVO</a
                        >
                    </div>
                </div>
                <span class="text-gray-600">|</span>
                <a
                    class="hover:text-gold transition-colors"
                    href="/sobre-nosotros">SOBRE NOSOTROS</a
                >

                <!-- Prominent Search Bar -->
                <div class="relative items-center hidden lg:flex mr-4">
                    <span
                        class="material-symbols-outlined absolute left-4 text-gray-400 text-[18px]"
                        >search</span
                    >
                    <input
                        type="text"
                        placeholder="Buscar..."
                        class="search-input bg-black/20 border border-white/20 text-white text-sm rounded-full pl-10 pr-4 py-2 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold transition-colors w-40 lg:w-56 placeholder:text-gray-300 backdrop-blur-sm shadow-inner"
                    />
                </div>

                <div class="flex items-center gap-1">
                    <div
                        class="p-2 rounded-full hover:bg-white/10 hover:text-gold transition-colors flex items-center justify-center open-cart-btn cursor-pointer relative"
                    >
                        <span class="material-symbols-outlined">local_mall</span
                        >
                        <!-- Badge para el carrito -->
                        <span
                            class="cart-badge hidden absolute top-0 right-0 bg-gold text-bg-dark text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center translate-x-1/4 -translate-y-1/4 shadow-md"
                        >
                            0
                        </span>
                    </div>

                    <!-- User Account Link -->
                    <a
                        href="/mi-cuenta"
                        class="p-2 rounded-full hover:bg-white/10 hover:text-gold transition-colors flex items-center justify-center focus:outline-none"
                        title="Mi Cuenta"
                    >
                        <span class="material-symbols-outlined">person</span>
                    </a>
                </div>
            </div>

            <div class="md:hidden flex items-center gap-2">
                <button class="text-white hover:text-gold p-2">
                    <span class="material-symbols-outlined text-2xl"
                        >search</span
                    >
                </button>
                <div
                    class="p-2 rounded-full hover:bg-white/10 hover:text-gold transition-colors flex items-center justify-center open-cart-btn cursor-pointer relative"
                >
                    <span class="material-symbols-outlined">local_mall</span>
                </div>
                <button
                    id="mobile-menu-btn"
                    class="text-white hover:text-gold p-2"
                >
                    <span class="material-symbols-outlined text-3xl">menu</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div
        id="mobile-menu"
        class="hidden md:hidden bg-secondary/95 backdrop-blur-md text-white border-t border-white/10 w-full px-4 pt-2 pb-4 space-y-4 absolute top-full left-0 z-50"
    >
        <div class="relative items-center flex mt-2 mb-4">
            <span
                class="material-symbols-outlined absolute left-4 text-gray-400 text-[18px]"
                >search</span
            >
            <input
                type="text"
                placeholder="Buscar..."
                class="search-input w-full bg-black/20 border border-white/20 text-white text-sm rounded-full pl-10 pr-4 py-3 focus:outline-none focus:border-gold transition-colors placeholder:text-gray-300"
            />
        </div>
        <a
            href="/productos"
            class="block py-2 text-sm font-bold uppercase tracking-widest text-white hover:text-gold transition-colors border-b border-white/10"
            >Productos</a
        >
        <div class="pl-4 space-y-2 pb-2 border-b border-white/10">
            <a
                href="/microdosis"
                class="block py-1.5 text-xs text-gray-300 hover:text-gold transition-colors"
                >— Microdosis</a
            >
            <a
                href="/trufas"
                class="block py-1.5 text-xs text-gray-300 hover:text-gold transition-colors"
                >— Trufas Mágicas</a
            >
            <a
                href="/kits-de-cultivo"
                class="block py-1.5 text-xs text-gray-300 hover:text-gold transition-colors"
                >— Kits de Cultivo</a
            >
        </div>
        <a
            href="/sobre-nosotros"
            class="block py-2 text-sm font-bold uppercase tracking-widest text-white hover:text-gold transition-colors border-b border-white/10"
            >Sobre Nosotros</a
        >
        <a
            href="/mi-cuenta"
            class="block py-2 text-sm font-bold uppercase tracking-widest text-white hover:text-gold transition-colors"
            >Mi Cuenta</a
        >
    </div>
</nav>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const mobileMenuBtn = document.getElementById("mobile-menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const icon = mobileMenuBtn?.querySelector("span");

        if (mobileMenuBtn && mobileMenu && icon) {
            mobileMenuBtn.addEventListener("click", () => {
                mobileMenu.classList.toggle("hidden");
                icon.textContent = mobileMenu.classList.contains("hidden")
                    ? "menu"
                    : "close";
            });
        }

        // Logic for search bar
        const searchInputs = document.querySelectorAll(".search-input");
        searchInputs.forEach((input) => {
            input.addEventListener("keypress", (e: any) => {
                if (e.key === "Enter" && e.target.value.trim() !== "") {
                    window.location.href = `/productos?q=${encodeURIComponent(
                        e.target.value.trim()
                    )}`;
                }
            });
        });
    });
</script>
