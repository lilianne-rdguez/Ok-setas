---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";

const trufasProducts = [
    {
        title: "Trufas Atlantis",
        subtitle: "Trufas Mágicas Psilocybe",
        price: "16,95 €",
        image: "https://ximoe124.sg-host.com/wp-content/uploads/2026/01/trufas-magicas-psilocybe-atlantis-500x500.jpg",
        badge: "Más Vendido",
        potency: 3,
        features: [
            "Efectos Visuales Claros",
            "Viaje Recreativo y Social",
            "Cultivo Especializado",
        ],
        url: "/producto/trufas-atlantis",
    },
    {
        title: "Trufas Cattaleya",
        subtitle: "Trufas Mágicas Psilocybe",
        price: "22,95 €",
        image: "https://ximoe124.sg-host.com/wp-content/uploads/2026/01/trufas-magicas-psilocybe-cattaleya-1-500x500.jpg",
        badge: "Premium",
        potency: 5,
        features: [
            "Alta Capacidad Introspectiva",
            "Sinergia Sensorial Aguda",
            "Sugerido para Iniciados",
        ],
        url: "/producto/trufas-cattaleya",
    },
    {
        title: "Trufas Hollandia",
        subtitle: "Trufas Mágicas Psilocybe",
        price: "21,50 €",
        image: "https://ximoe124.sg-host.com/wp-content/uploads/2022/04/trufas-magicas-psilocybe-hollandia-500x500.jpg",
        badge: "Alta Potencia",
        potency: 4,
        features: [
            "Líderes en Intensidad",
            "Viaje Extremo Filosófico",
            "Sólo Usuarios Experimentados",
        ],
        url: "/producto/trufas-hollandia",
    },
];
---

<Layout title="Trufas Mágicas | GrowTrades">
    <Header />

    <main class="min-h-screen bg-bg-dark text-white overflow-hidden relative">
        <!-- Decoración de fondo -->
        <div
            class="absolute top-0 right-0 w-[600px] h-[600px] bg-gradient-to-bl from-green-500/10 to-transparent rounded-full blur-[100px] pointer-events-none z-0"
        >
        </div>
        <div
            class="absolute bottom-0 left-0 w-[800px] h-[800px] bg-gradient-to-tr from-yellow-700/5 to-transparent rounded-full blur-[120px] pointer-events-none z-0"
        >
        </div>

        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24 relative z-10"
        >
            <!-- Sección Hero: Introducción a Trufas -->
            <div
                class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24 mb-32"
            >
                <div class="flex-1 text-center lg:text-left animate-fade-in-up">
                    <span
                        class="text-primary font-bold tracking-widest uppercase text-sm mb-4 block"
                        >El Mundo Subterráneo</span
                    >
                    <h1
                        class="font-display text-4xl md:text-6xl leading-tight text-white mb-6 tracking-[-0.02em] uppercase"
                    >
                        Poder <br />
                        <span class="text-gold italic block mt-2"
                            >Ancestral</span
                        >
                    </h1>
                    <p
                        class="text-gray-200 text-lg md:text-xl font-light leading-relaxed text-pretty mb-10 max-w-2xl mx-auto lg:mx-0"
                    >
                        Las trufas mágicas te invitan a explorar los límites de
                        tu imaginación. Cuidadosamente seleccionadas y empacadas
                        al vacío para garantizar la mejor calidad y un viaje
                        seguro.
                    </p>
                    <div
                        class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4"
                    >
                        <a
                            href="#comprar"
                            class="bg-gold text-bg-dark font-bold px-8 py-4 rounded-full hover:bg-white transition-colors duration-300 uppercase tracking-widest text-sm shadow-[0_0_20px_rgba(255,215,0,0.3)] hover:shadow-[0_0_30px_rgba(255,255,255,0.4)]"
                        >
                            Ver Catálogo
                        </a>
                    </div>
                </div>

                <div class="flex-1 flex justify-center lg:justify-end">
                    <div class="w-full max-w-sm">
                        <img
                            src="https://ximoe124.sg-host.com/wp-content/uploads/2026/01/Captura-de-pantalla-2026-01-19-094506.png"
                            alt="Trufas Mágicas GrowTrades"
                            class="w-full h-auto object-contain rounded-2xl shadow-xl border border-white/5"
                        />
                    </div>
                </div>
            </div>

            <!-- Productos Disponibles -->
            <section id="comprar" class="relative">
                <div class="text-center mb-10">
                    <h2
                        class="text-3xl md:text-4xl font-bold text-white uppercase tracking-widest mb-4"
                    >
                        Tipos de <span class="text-gold">Sclerotia</span>
                    </h2>
                    <div
                        class="h-1 w-16 bg-gradient-to-r from-transparent via-gold to-transparent mx-auto mb-6"
                    >
                    </div>
                    <p class="text-gray-400 max-w-2xl mx-auto">
                        Cosechadas en su momento óptimo de madurez. Tenemos
                        desde opciones suaves para principiantes hasta joyas
                        raras para exploradores expertos.
                    </p>
                </div>

                <!-- Opciones de filtrado/ordenación -->
                <div
                    class="flex flex-wrap items-center justify-between mb-12 border-b border-white/10 pb-6 relative z-10 gap-4"
                >
                    <p
                        class="text-[10px] sm:text-xs font-bold text-gray-500 uppercase tracking-widest"
                    >
                        3 productos encontrados
                    </p>
                    <!-- Custom Potency/Price Dropdown -->
                    <div
                        class="relative min-w-[240px]"
                        id="custom-select-wrapper"
                    >
                        <label
                            class="absolute -top-6 left-1 text-[9px] uppercase tracking-[0.2em] text-gray-500 font-bold"
                            >Ordenar por</label
                        >
                        <button
                            id="custom-select-trigger"
                            class="w-full bg-white/5 backdrop-blur-md border border-white/10 text-white text-[10px] sm:text-xs uppercase tracking-widest font-bold rounded-xl pl-5 pr-10 py-3.5 focus:outline-none focus:border-gold/50 cursor-pointer transition-all hover:bg-white/10 hover:border-white/20 flex items-center justify-between group shadow-lg"
                        >
                            <span id="select-label">Más Populares</span>
                            <span
                                class="material-symbols-outlined text-gold group-hover:rotate-180 transition-transform duration-500 text-[18px]"
                                >expand_more</span
                            >
                        </button>

                        <ul
                            id="custom-select-options"
                            class="absolute top-[calc(100%+8px)] left-0 right-0 bg-[#121212] border border-white/10 rounded-xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-all duration-300 opacity-0 translate-y-4 pointer-events-none z-[100] backdrop-blur-xl"
                        >
                            <li
                                data-value="populares"
                                class="px-5 py-3.5 text-white/70 text-[10px] sm:text-xs uppercase tracking-widest font-bold hover:bg-gold hover:text-bg-dark cursor-pointer transition-colors border-b border-white/5"
                            >
                                Más Populares
                            </li>
                            <li
                                data-value="price-asc"
                                class="px-5 py-3.5 text-white/70 text-[10px] sm:text-xs uppercase tracking-widest font-bold hover:bg-gold hover:text-bg-dark cursor-pointer transition-colors border-b border-white/5"
                            >
                                Precio: Menor a Mayor
                            </li>
                            <li
                                data-value="price-desc"
                                class="px-5 py-3.5 text-white/70 text-[10px] sm:text-xs uppercase tracking-widest font-bold hover:bg-gold hover:text-bg-dark cursor-pointer transition-colors border-b border-white/5"
                            >
                                Precio: Mayor a Menor
                            </li>
                            <li
                                data-value="potency"
                                class="px-5 py-3.5 text-white/70 text-[10px] sm:text-xs uppercase tracking-widest font-bold hover:bg-gold hover:text-bg-dark cursor-pointer transition-colors"
                            >
                                Máxima Potencia
                            </li>
                        </ul>
                        <input
                            type="hidden"
                            id="trufas-sort"
                            value="populares"
                        />
                    </div>
                </div>

                <div
                    id="trufas-grid"
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative z-10"
                >
                    {
                        trufasProducts.map((prod) => (
                            <div
                                data-price={prod.price}
                                data-potency={prod.potency}
                                class="product-item bg-white/5 backdrop-blur-xl rounded-[2rem] border border-white/10 p-8 shadow-2xl flex flex-col group hover:-translate-y-2 hover:border-gold/30 transition-all duration-500"
                            >
                                <div class="relative w-full aspect-square bg-white rounded-2xl overflow-hidden p-6 flex items-center justify-center mb-8 shadow-inner">
                                    {prod.badge && (
                                        <div class="absolute top-3 left-3 bg-gold text-bg-dark text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest z-20 shadow-lg">
                                            {prod.badge}
                                        </div>
                                    )}
                                    <img
                                        src={prod.image}
                                        alt={prod.title}
                                        class="w-full h-full object-contain transform group-hover:scale-110 group-hover:-rotate-2 transition-all duration-700 ease-out drop-shadow-xl"
                                    />
                                </div>

                                <div class="flex-1 flex flex-col">
                                    <span class="text-gold uppercase tracking-widest text-[10px] font-bold mb-2 block">
                                        {prod.subtitle}
                                    </span>
                                    <h3 class="text-2xl font-bold text-white mb-4 tracking-tight leading-tight">
                                        {prod.title}
                                    </h3>

                                    <div class="mb-6">
                                        <span class="text-3xl font-mono text-white font-bold tracking-tighter">
                                            {prod.price}
                                        </span>
                                    </div>

                                    <ul class="space-y-3 mb-8 text-left flex-1">
                                        {prod.features.map((feature) => (
                                            <li class="flex items-start gap-2">
                                                <span class="material-symbols-outlined text-gold mt-0.5 text-sm">
                                                    check_circle
                                                </span>
                                                <span class="text-gray-300 text-sm font-light leading-snug">
                                                    {feature}
                                                </span>
                                            </li>
                                        ))}
                                    </ul>

                                    <div class="grid grid-cols-2 gap-3 w-full mt-auto relative z-20">
                                        <button
                                            class="btn-add-category bg-[#A03D45] text-white font-bold py-3 px-6 rounded-xl hover:bg-red-800 transition-all duration-300 flex items-center justify-center gap-3 uppercase tracking-widest text-[10px] sm:text-xs shadow-[0_4px_20px_rgba(160,61,69,0.3)]"
                                            data-product={JSON.stringify(prod)}
                                        >
                                            <span class="material-symbols-outlined text-sm">
                                                shopping_cart
                                            </span>
                                            Añadir
                                        </button>
                                        <a
                                            href={prod.url}
                                            class="bg-transparent border border-white/20 text-white font-bold py-3 px-2 rounded-xl uppercase tracking-widest hover:border-gold hover:text-gold transition-all duration-300 flex justify-center items-center gap-2 text-[10px] sm:text-xs h-full"
                                        >
                                            <span class="material-symbols-outlined text-sm">
                                                visibility
                                            </span>
                                            Info
                                        </a>
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </section>
        </div>
    </main>

    <style>
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .animate-fade-in-up {
            animation: fadeInUp 0.8s ease-out forwards;
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const catAddBtns = document.querySelectorAll(".btn-add-category");
            catAddBtns.forEach((btn) => {
                btn.addEventListener("click", (e) => {
                    const button = e.currentTarget as HTMLElement;
                    const productData = JSON.parse(
                        button.dataset.product || "{}"
                    );
                    if ((window as any).addToCartGlobal) {
                        const id =
                            productData.id ||
                            productData.url?.split("/").pop() ||
                            productData.title
                                ?.replace(/\s+/g, "-")
                                .toLowerCase();
                        (window as any).addToCartGlobal({
                            ...productData,
                            id,
                            quantity: 1,
                        });
                    } else {
                        console.error("CartDrawer not ready");
                        if (typeof (window as any).openCart === "function")
                            (window as any).openCart();
                    }
                });
            });

            // -- Custom Select UI Logic --
            const selectTrigger = document.getElementById(
                "custom-select-trigger"
            );
            const selectOptions = document.getElementById(
                "custom-select-options"
            );
            const selectLabel = document.getElementById("select-label");
            const sortInput = document.getElementById(
                "trufas-sort"
            ) as HTMLInputElement;
            const optionItems = selectOptions?.querySelectorAll("li");
            const gridContainer = document.getElementById("trufas-grid");

            if (selectTrigger && selectOptions) {
                selectTrigger.addEventListener("click", (e) => {
                    e.stopPropagation();
                    selectOptions.classList.toggle("opacity-0");
                    selectOptions.classList.toggle("translate-y-4");
                    selectOptions.classList.toggle("pointer-events-none");
                });

                document.addEventListener("click", () => {
                    selectOptions.classList.add("opacity-0");
                    selectOptions.classList.add("translate-y-4");
                    selectOptions.classList.add("pointer-events-none");
                });

                optionItems?.forEach((item) => {
                    item.addEventListener("click", () => {
                        const val =
                            item.getAttribute("data-value") || "populares";
                        if (sortInput) sortInput.value = val;
                        if (selectLabel)
                            selectLabel.textContent =
                                item.textContent?.trim() || "";
                        applySort();
                    });
                });
            }

            function applySort() {
                if (!gridContainer || !sortInput) return;
                const products = Array.from(
                    gridContainer.querySelectorAll(".product-item")
                ) as HTMLElement[];
                const sortValue = sortInput.value;

                products.sort((a, b) => {
                    if (
                        sortValue === "price-asc" ||
                        sortValue === "price-desc"
                    ) {
                        const getV = (el: HTMLElement) => {
                            const raw = el.dataset.price || "0";
                            return (
                                parseFloat(
                                    raw
                                        .replace(/[^\d.,]/g, "")
                                        .replace(",", ".")
                                ) || 0
                            );
                        };
                        const priceA = getV(a);
                        const priceB = getV(b);
                        return sortValue === "price-asc"
                            ? priceA - priceB
                            : priceB - priceA;
                    }

                    if (sortValue === "potency") {
                        const potA = parseInt(a.dataset.potency || "0");
                        const potB = parseInt(b.dataset.potency || "0");
                        return potB - potA; // Mayor potencia primero
                    }

                    return 0;
                });

                // Re-append sorted elements
                products.forEach((p) => gridContainer.appendChild(p));
            }
        });
    </script>
</Layout>
